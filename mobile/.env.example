# Supabase — copy this file to `.env` and fill in your project values.
# Find these in Supabase dashboard → Project Settings → API.
#
# The anon key is PUBLIC (safe to ship in the app). Never put the
# service_role key here — it goes in the scraper's own env only.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── Scraper env (scripts/scrape-events.mjs only — server-side, keep secret) ──

# Service role key (Supabase → Settings → API). Lets the scraper WRITE events.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Eventbrite official API — pulls events for ORGANIZATIONS you own/follow only.
# (Eventbrite removed public city-wide search in 2020 — there is no "all Naples"
# endpoint.) Token: eventbrite.com → Account → Developer Links → API Keys →
# "Private token". EVENTBRITE_ORG_IDS is comma-separated; default is the org
# from the URL Erik gave (58388869923).
# EVENTBRITE_TOKEN=YOUR-PRIVATE-TOKEN
# EVENTBRITE_ORG_IDS=58388869923

# Bandsintown official API — ARTIST-based (no public city endpoint). Provide an
# app_id (register at artists.bandsintown.com/support/api-installation) and a
# comma-separated artist list; only their Naples-area dates are kept.
# BANDSINTOWN_APP_ID=helpmenapoli
# BANDSINTOWN_ARTISTS=Geolier,Liberato,Nu Genea,Gigi D'Alessio

# TicketOne + Dice use Playwright (no API keys). Enable once with:
#   npx playwright install chromium
