export type Spot = {
  rank: number;
  name: string;
  area?: string;
  description?: string;
  tag?: string;
  lat: number;
  lng: number;
};

export type DiscoverList = {
  id: string;
  label: string;
  group: 'food' | 'activity';
  sub: 'food' | 'drink' | 'day' | 'night';
  image: string; // remote fallback; provided photos live in topImages keyed by id
  blurb: string;
  note?: string;
  items: Spot[];
};

const img = (kw: string, lock: number) => `https://loremflickr.com/640/360/${kw}?lock=${lock}`;

